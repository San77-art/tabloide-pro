EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Gemini AI
EXPO_PUBLIC_GEMINI_API_KEY=

# OpenAI (geração de fundos com DALL-E 3)
EXPO_PUBLIC_OPENAI_KEY=

# Cloudinary (CLOUDINARY_API_SECRET fica só no servidor/scripts, nunca no bundle do app)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# remove.bg (remoção de fundo de fotos de produto)
EXPO_PUBLIC_REMOVE_BG_KEY=

# Pexels (banco de imagens expandido)
EXPO_PUBLIC_PEXELS_KEY=

# Mercado Pago (MP_ACCESS_TOKEN é sensível — usado apenas no backend/ (Railway), nunca no bundle do app)
EXPO_PUBLIC_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

# Backend próprio (Express no Railway) que faz as chamadas ao Mercado Pago
EXPO_PUBLIC_BACKEND_URL=
