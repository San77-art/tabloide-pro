rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Nome do mercado é público para o link compartilhável do tabloide
    match /markets/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /products/{productId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

    // Tabloides publicados são públicos; os demais são privados do dono
    match /tabloids/{tabloidId} {
      allow read: if resource.data.status == 'published';
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

    // Banco de imagens públicas: leitura para qualquer autenticado, escrita só para admin
    match /public_products/{productId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Configuração de cotação/alertas do lojista
    match /exchange_rates/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Plano de assinatura: upgrades via backend/Admin SDK
    match /subscriptions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.plan == 'free';
      allow update, delete: if false;
    }

    // Token de push notification do device
    match /push_tokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Contador mensal de gerações de fundo com IA
    match /ai_usage/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Feed de atividades recentes do lojista
    match /activities/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Anúncios de marcas parceiras: leitura para qualquer autenticado, escrita só via Console/admin
    match /ads/{adId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
